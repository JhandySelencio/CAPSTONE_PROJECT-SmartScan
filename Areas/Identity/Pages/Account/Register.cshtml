@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

@section Styles {
    <style>
        body {
            background: linear-gradient(180deg, #f7d14d 32%, #eebe3a 70%, #da9e22 100%);
            background-repeat: no-repeat;
            background-size: cover;
        }
    </style>
}

<div class="row bg-white col-md-5 position-absolute top-50 start-50 translate-middle mt-4 border border-0 rounded-4">
    <div class="p-4 pt-2">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <h3 class="text-center pb-3 pt-2">@ViewData["Title"]</h3>
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <!-- [If you want to add FirstName and LastName Fields]
                <div class="row">
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.FirstName" class="form-control" autocomplete="given-name" aria-required="true" placeholder="John" />
                        <label asp-for="Input.FirstName">First Name</label>
                        <span asp-for="Input.FirstName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.LastName" class="form-control" autocomplete="family-name" aria-required="true" placeholder="Doe" />
                        <label asp-for="Input.LastName">Last Name</label>
                        <span asp-for="Input.LastName" class="text-danger"></span>
                    </div>
                </div>
            </div>
            -->
            <div class="form-floating mb-3 text-secondary">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3 text-secondary">
                <select asp-for="Input.Role" class="form-select" aria-required="true">
                    <option value="Cashier">Cashier</option>
                    <option value="Admin">Administrator</option>
                </select>
                <label asp-for="Input.Role">Role</label>
                <span asp-for="Input.Role" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3 text-secondary">
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.Password">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3 text-secondary">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>
            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary fw-semibold border border-0" style="background-color:#FC9C00;">Create Account</button>
        </form>
    </div>
</div>

@if (TempData["Message"] != null)
{
    <script type="text/javascript">
        alert("@TempData["Message"]");
    </script>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

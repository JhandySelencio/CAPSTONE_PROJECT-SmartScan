@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

@section Styles {
    <style>
        body{
            background: linear-gradient(180deg, #f7d14d 32%, #eebe3a 70%, #da9e22 100%);
        }
    </style>
}
<div class="con bg-white col-md-5 position-absolute top-50 start-50 translate-middle mt-4 border border-0 rounded-4 ">
    <div class="p-4">
        <section>
            <form id="account" method="post">
                <h2 class="text-center pb-4">Login</h2>
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3 text-secondary">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3 text-secondary">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="row align-items-start">
                    <div class="checkbox mb-3 col">
                        <label asp-for="Input.RememberMe" class="form-label">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>
                    <div class="col text-end">
                        <p>
                            <a style="color: #FF8800;" class="fw-semibold" id="forgot-password" asp-page="./ForgotPassword">Forgot password?</a>
                        </p>
                    </div>
                </div>
                <div class="p-2">
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary fw-semibold border border-0" style="background-color:#FC9C00;">Log In</button>
                </div>
                <div>
                    <p class="pt-4 text-center"> Don't have an account? 
                        <a style="color: #FF8800;" class=" fw-semibold" asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register Here!</a>
                    </p>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

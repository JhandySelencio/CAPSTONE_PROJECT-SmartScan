@{
    ViewData["Title"] = "Checkout Page";
    ViewData["HeaderTitle"] = "Checkout";
}

@section Styles {
    <style>
        body {
            background: linear-gradient(0deg, #ff930f 0%, #fff95b 100%);
            background-repeat: no-repeat;
            background-size: cover;
        }
    </style>
}

<div class="container-fluid mt-3">
    <div class="row g-4" style="height: calc(100vh - 130px);">

        <div class="col-md-7 d-flex flex-column h-100">
            <div class="card shadow border-0 bg-dark text-white flex-grow-1 position-relative d-flex align-items-center justify-content-center overflow-hidden rounded-3">

                <video id="webcamFeed" autoplay playsinline class="w-100 h-100" style="object-fit: cover; display: none;"></video>

                <div id="cameraPlaceholder" class="text-center p-4">
                    <i class="fa-solid fa-video-slash fa-4x text-secondary mb-3"></i>
                    <h4 class="text-secondary fw-semibold">Webcam Disabled</h4>
                    <p class="text-muted small">Click the action button below to grant permission and initiate feed.</p>
                </div>

                <div class="position-absolute bottom-0 start-50 translate-middle-x mb-3 z-3">
                    <button id="startCamBtn" class="btn btn-warning fw-semibold shadow px-4 py-2">
                        <i class="fa-solid fa-camera me-2"></i> Enable Webcam
                    </button>
                    <button id="stopCamBtn" class="btn btn-danger fw-semibold shadow px-4 py-2 d-none">
                        <i class="fa-solid fa-video-slash me-2"></i> Stop Feed
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-5 d-flex flex-column h-100">
            <div class="card shadow border-0 h-100 rounded-3">
                <div class="card-header bg-dark text-white p-3 d-flex align-items-center justify-content-between">
                    <h5 class="mb-0"><i class="fa-solid fa-list-check text-warning me-2"></i> Identified Items</h5>
                </div>

                <div class="card-body overflow-y-auto flex-grow-1 p-0" style="max-height: 100%;">
                    <div class="list-group list-group-flush" id="logListItems">

                        <ul> <!--Place here if the items are identified -->
                            <li>
                                <p>Kape</p>
                            </li>
                        </ul>

                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script type="text/javascript">
        document.addEventListener("DOMContentLoaded", function () {
            const video = document.getElementById("webcamFeed");
            const placeholder = document.getElementById("cameraPlaceholder");
            const startBtn = document.getElementById("startCamBtn");
            const stopBtn = document.getElementById("stopCamBtn");
            let streamInstance = null;

            // 1. START WEBCAM ACTION HANDLER
            startBtn.addEventListener("click", async function () {
                try {
                    // Requests camera-only media permission hook natively
                    streamInstance = await navigator.mediaDevices.getUserMedia({
                        video: { width: 1280, height: 720, facingMode: "user" },
                        audio: false
                    });

                    // Bind the raw stream array to the video viewport container
                    video.srcObject = streamInstance;

                    // Toggle visibility states cleanly
                    placeholder.style.display = "none";
                    video.style.display = "block";
                    startBtn.classList.add("d-none");
                    stopBtn.classList.remove("d-none");
                } catch (err) {
                    console.error("Error accessing webcam: ", err);
                    alert("Unable to access local hardware camera device. Ensure permission is allowed in your browser address bar properties control.");
                }
            });

            // 2. STOP WEBCAM ACTION HANDLER
            stopBtn.addEventListener("click", function () {
                if (streamInstance) {
                    // Turn off all individual camera tracks explicitly to stop hardware indicator lights
                    streamInstance.getTracks().forEach(track => track.stop());
                    video.srcObject = null;
                }

                // Reset layouts back to placeholder states
                video.style.display = "none";
                placeholder.style.display = "block";
                stopBtn.classList.add("d-none");
                startBtn.classList.remove("d-none");
            });
        });
    </script>
}

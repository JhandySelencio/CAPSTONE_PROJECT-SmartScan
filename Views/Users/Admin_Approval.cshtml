@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>
@inject Microsoft.AspNetCore.Identity.UserManager<Microsoft.AspNetCore.Identity.IdentityUser> UserManager
@{
    ViewData["Title"] = "Admin Approval";
    ViewData["HeaderTitle"] = "Admin Account Approval";
}

@section Styles {
    <style>
        body {
            background: linear-gradient(0deg, #ff930f 0%, #fff95b 100%);
            background-repeat: no-repeat;
            background-size: cover;
        }
    </style>
}

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-dark text-white p-3">
        <h5 class="mb-0"><i class="fa-solid fa-user-pen"></i> Pending Admin Approval </h5>
    </div>
    <div class="card-body">

        @if (TempData["UserMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fa-solid fa-circle-check"></i> @TempData["UserMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="text-muted mb-3">
                    <i class="fa-solid fa-folder-open fa-3x text-secondary opacity-50"></i>
                </div>
                <h4 class="fw-semibold text-secondary">Empty Admin Approvals</h4>
                <p class="text-muted small">All registering administrators have been verified and processed.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Username / Email</th>
                            <th>Account Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>
                                    <i class="fa-solid fa-user text-secondary me-2"></i> @user.UserName
                                </td>
                                <td>
                                    <span class="badge bg-warning text-dark rounded-pill px-3">Pending Approval</span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="Approve" asp-route-id="@user.Id" class="btn btn-sm btn-outline-success">
                                        <i class="fa-solid fa-check"></i> Approve Admin
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>